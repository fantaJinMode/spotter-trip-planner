# Local development environment variables. Do not commit real secrets.
# On Vercel, define these under Project Settings > Environment Variables.
# Vercel also sets VERCEL_URL automatically in deployments to help ALLOWED_HOSTS.
DEBUG=True
SECRET_KEY=change-me-in-production
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
